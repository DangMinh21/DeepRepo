# Copy file này thành .env và điền API keys

# AI Provider — chọn 1 trong 2
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model mặc định (LiteLLM format)
# Claude: claude-sonnet-4-6 hoặc claude-opus-4-6
# OpenAI: gpt-4o hoặc gpt-4o-mini
AI_MODEL=claude-sonnet-4-6

# GitHub Token (optional nhưng tăng rate limit từ 60 lên 5000 requests/hour)
GITHUB_TOKEN=your_github_token_here

# Redis (optional cho MVP — dùng in-memory nếu không có)
REDIS_URL=redis://localhost:6379
